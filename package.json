{
  "name": "walkie-app-project-m",
  "version": "1.0.0",
  "productName": "Walkie-App-Project-M",
  "description": "Walkie-App-Project-M — WhatsApp-like messaging with Firebase (project: walkie-app-project-m), real-time chats, calls, communities and themes",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "web": "vite preview",
    "web:node": "npx serve . -p 8080",
    "build": "vite build",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "push": "powershell -ExecutionPolicy Bypass -File ./push.ps1",
    "ship": "powershell -ExecutionPolicy Bypass -File ./push.ps1 && firebase deploy --only hosting",
    "auto-push": "powershell -ExecutionPolicy Bypass -File ./auto-push.ps1",
    "watch": "powershell -ExecutionPolicy Bypass -File ./auto-push.ps1",
    "pack": "electron-builder --win --x64",
    "build:electron": "electron-builder --win --x64"
  },
  "keywords": [
    "electron",
    "chat",
    "messaging",
    "whatsapp",
    "calls",
    "offline"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.mos.walkieapp",
    "productName": "Social App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "renderer.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Social-App-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "firebase": "^12.14.0"
  }
}
