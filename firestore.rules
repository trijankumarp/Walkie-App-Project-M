rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    // (for theme etc.)
    match /users/{userId} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId;

      // recentCalls subcollection - only the owner
      match /recentCalls/{callId} {
        allow read, write: if request.auth != null 
          && request.auth.uid == userId;
      }
    }

    // Chats: only members of the chat can read or write the chat doc
    match /chats/{chatId} {
      // Read a chat only if you are in the members list
      allow read: if request.auth != null 
        && request.auth.uid in resource.data.members;

      // Create a chat only if you include yourself in members
      allow create: if request.auth != null 
        && request.auth.uid in request.resource.data.members;

      // Update chat (e.g. lastMessage) only if you are a member
      allow update: if request.auth != null 
        && request.auth.uid in resource.data.members;

      // Messages subcollection under a chat
      match /messages/{messageId} {
        // Can read messages only if member of the parent chat
        allow read: if request.auth != null 
          && request.auth.uid in 
            get(/databases/$(database)/documents/chats/$(chatId)).data.members;

        // Can write (send) messages only if member of the parent chat
        allow create: if request.auth != null 
          && request.auth.uid in 
            get(/databases/$(database)/documents/chats/$(chatId)).data.members;

        // No editing or deleting old messages (for simplicity)
        allow update, delete: if false;
      }
    }

    // Communities: authenticated users can read all and create new ones
    // (global "groups that matter to you")
    match /communities/{communityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      // Only the creator can update/delete (optional, for safety)
      allow update, delete: if request.auth != null 
        && request.auth.uid == resource.data.createdBy;
    }
  }
}
